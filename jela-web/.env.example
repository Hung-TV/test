# API gốc của JELA backend.
VITE_API_BASE_URL=http://localhost:8080/api

# OAuth Client ID là giá trị public dành cho frontend, nhưng vẫn tách theo
# môi trường để local/staging/production có thể dùng các Google app khác nhau.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Giữ true khi phát triển UI bằng dữ liệu giả. Đổi thành false khi các API
# Kanji, learning list và MyDeck của backend đã sẵn sàng.
VITE_USE_FAKE_KANJI_API=true
VITE_USE_FAKE_LEARNING_LIST_API=true
VITE_USE_FAKE_DECK_API=true

# Các path endpoint tập trung tại src/api/apiConfig.js.
